---
const sebab = [
  {
    icon: '🎪',
    chip: 'bg-sunny/40',
    tajuk: 'Berpengalaman & Boleh Dipercayai',
    isi: '9 tahun, ratusan majlis dari birthday party rumah sampai event korporat dan karnival sekolah.',
  },
  {
    icon: '🧒',
    chip: 'bg-mint/20',
    tajuk: 'Kanak-Kanak Yang Jadi Keutamaan',
    isi: 'Persembahan disesuaikan ikut umur. Dari yang pemalu sampai yang paling aktif, semua akan terhibur.',
  },
  {
    icon: '💬',
    chip: 'bg-coral/15',
    tajuk: 'Senang & Telus',
    isi: 'Harga terpampang, book online, confirmation dalam 1 jam. Takde PM-PM tanya harga.',
  },
];
---

<section class="py-16 md:py-24">
  <div class="mx-auto max-w-[1100px] px-5">
    <h2 class="squiggle mx-auto w-fit text-center text-3xl font-bold md:text-4xl">
      Kenapa Badut Jim?
    </h2>

    <div class="mt-14 grid gap-6 md:grid-cols-3">
      {
        sebab.map((s) => (
          <div class="tilt rounded-3xl bg-white p-8 shadow-sm">
            <div class:list={['flex h-14 w-14 items-center justify-center rounded-2xl text-3xl', s.chip]} aria-hidden="true">
              {s.icon}
            </div>
            <h3 class="mt-4 text-xl font-semibold">{s.tajuk}</h3>
            <p class="mt-2 text-[15px] opacity-90">{s.isi}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
