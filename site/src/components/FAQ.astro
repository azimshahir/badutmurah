---
// FAQ pill rows with emoji icons. Copy from i18n dicts (synced with docs/content.md)
import { getT } from '../i18n/index.js';

const { locale = 'en' } = Astro.props;
const t = getT(locale);
---

<section id="faq" class="scroll-mt-28 py-16 md:py-24">
  <div class="mx-auto max-w-[760px] px-5">
    <h2 class="squiggle mx-auto w-fit text-center text-3xl font-bold md:text-4xl">
      {t.faq.heading}
    </h2>

    <div class="mt-10 space-y-3">
      {
        t.faq.items.map((item) => (
          <details class="group rounded-2xl bg-white p-4 shadow-sm transition-shadow open:shadow-md hover:shadow-md">
            <summary class="flex cursor-pointer list-none items-center gap-3 font-display text-lg font-bold [&::-webkit-details-marker]:hidden">
              <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-cream text-lg" aria-hidden="true">
                {item.emoji}
              </span>
              <span class="flex-1">{item.q}</span>
              <span class="shrink-0 text-sm text-coral transition-transform group-open:rotate-180" aria-hidden="true">▼</span>
            </summary>
            <p class="mt-2 pr-2 pl-12 text-[15px] opacity-80">{item.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>
