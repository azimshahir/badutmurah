---
// Organic wave divider between sections (design-brief: bentuk blob/lengkung organik)
// `from` = background of the section above, `to` = background of the section below.
const { from = '#FFFBF5', to = '#FFFFFF' } = Astro.props;
---

<div style={`background:${from}`} aria-hidden="true">
  <svg viewBox="0 0 1440 48" preserveAspectRatio="none" class="block h-8 w-full md:h-12">
    <path
      d="M0,26 C160,46 340,4 640,18 C940,32 1180,6 1440,26 L1440,48 L0,48 Z"
      fill={to}></path>
  </svg>
</div>
