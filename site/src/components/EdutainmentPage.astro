---
// Edutainment Projects page: fun coding side-projects for kids, not a service menu.
import Layout from '../layouts/Layout.astro';
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';
import WhatsAppButton from './WhatsAppButton.astro';
import { getT, getWhatsAppLink, localePath } from '../i18n/index.js';

const { locale = 'en' } = Astro.props;
const t = getT(locale);
const pathname = localePath(locale, '/edutainment');
const waLink = getWhatsAppLink(locale);
---

<Layout locale={locale} title={t.meta.titleEdutainment} description={t.meta.descriptionEdutainment} pathname={pathname}>
  <Navbar locale={locale} pathname={pathname} />
  <main class="mx-auto max-w-[900px] px-5 py-14 md:py-20">
    <h1 class="squiggle mx-auto w-fit text-center text-4xl font-bold md:text-5xl">
      {t.edutainment.heading}
    </h1>
    <p class="mx-auto mt-6 max-w-2xl text-center text-lg opacity-90">{t.edutainment.intro}</p>

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        t.edutainment.projects.map((proj, i) => {
          const chips = ['bg-sky', 'bg-coral/15', 'bg-yellow-100', 'bg-mint/20', 'bg-sky', 'bg-coral/15', 'bg-yellow-100'];
          return (
            <div class="tilt relative rounded-[32px] border border-navy/5 bg-white p-6 shadow-md">
              <span class="absolute -top-3 right-5 rounded-full bg-sunny px-3 py-1 font-display text-xs font-bold whitespace-nowrap shadow-md">
                ✨ {t.edutainment.comingSoon}
              </span>
              <div class:list={['flex h-14 w-14 items-center justify-center rounded-2xl text-2xl', chips[i % chips.length]]} aria-hidden="true">
                {proj.emoji}
              </div>
              <h2 class="mt-4 text-lg font-bold">{proj.tajuk}</h2>
              <p class="mt-2 text-sm opacity-80">{proj.isi}</p>
            </div>
          );
        })
      }

      <div class="flex flex-col items-center justify-center rounded-[32px] border-2 border-dashed border-navy/15 bg-white p-6 text-center shadow-sm">
        <p class="opacity-80">{t.edutainment.nota}</p>
        <a
          href={waLink}
          target="_blank"
          rel="noopener"
          class="pop gradient-green mt-4 rounded-full px-7 py-3 font-display text-lg font-bold text-white shadow-md"
        >
          {t.edutainment.cta}
        </a>
      </div>
    </div>
  </main>
  <Footer locale={locale} />
  <WhatsAppButton locale={locale} />
</Layout>
