---
// Package cards: 2 cards. Basic (with 2-hour variant inside) + Game Package.
// Data from docs/pricing.json (BM + _en fields), never hardcoded.
import pricing from '../../docs/pricing.json';
import { getT } from '../i18n/index.js';

const { locale = 'en' } = Astro.props;
const t = getT(locale);
const { pakej, currency } = pricing;
const f = (p, key) => p[t.pakej[key]];
const sesuaiKey = locale === 'en' ? 'sesuai_en' : 'sesuai';
const durasiKey = t.pakej.durasiKey;

const basic = pakej.find((p) => p.id === 'biasa-1jam');
const basic2 = pakej.find((p) => p.id === 'biasa-2jam');
const game = pakej.find((p) => p.id === 'meriah');
---

<section id="pakej" class="scroll-mt-28 py-16 md:py-24">
  <div class="mx-auto max-w-[900px] px-5">
    <h2 class="squiggle mx-auto w-fit text-center text-3xl font-bold md:text-4xl">
      {t.pakej.heading}
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-center opacity-90">{t.pakej.sub}</p>

    <div class="mt-14 grid items-stretch gap-6 md:grid-cols-2 md:gap-8">
      <!-- Basic Package: 1 hour, with 2-hour variant below -->
      <article class="tilt relative flex flex-col rounded-3xl border-2 border-navy/10 bg-white p-7">
        <h3 class="text-2xl font-semibold">{f(basic, 'nameKey')}</h3>
        <p class="text-sm font-semibold opacity-70">{basic[durasiKey]}</p>
        <p class="mt-4 font-display text-[2.75rem] leading-none font-bold">
          {currency}{basic.harga}
        </p>
        <p class="mt-3 text-sm opacity-80">{basic[sesuaiKey]}</p>
        <ul class="mt-5 flex-1 space-y-2.5 text-[15px]">
          {f(basic, 'termasukKey').map((item) => (
            <li class="flex gap-2">
              <span class="mt-0.5 shrink-0 font-bold text-mint">✓</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>

        <!-- 2-hour variant -->
        <div class="mt-6 rounded-2xl bg-cream p-4">
          <p class="font-display text-lg font-bold">
            {basic2[durasiKey]}: {currency}{basic2.harga}
          </p>
          <p class="mt-1 text-sm opacity-80">{basic2[sesuaiKey]}</p>
        </div>

        <a
          href="#booking"
          data-pakej={basic.id}
          class="pakej-cta pop mt-6 rounded-2xl border-2 border-coral py-3.5 text-center font-display text-xl font-bold text-coral-dark hover:bg-coral hover:text-white"
        >
          {t.pakej.book}
        </a>
      </article>

      <!-- Game Package (most popular) -->
      <article class="tilt relative flex flex-col rounded-3xl border-[3px] border-coral/50 bg-white p-7 shadow-xl shadow-coral/20 ring-4 ring-coral/10 md:-my-3 md:py-10">
        <span class="absolute -top-4 left-1/2 -translate-x-1/2 rounded-full bg-sunny px-5 py-1.5 font-display text-sm font-bold whitespace-nowrap shadow-md">
          ⭐ {f(game, 'labelKey')}
        </span>
        <h3 class="text-2xl font-semibold">{f(game, 'nameKey')}</h3>
        <p class="text-sm font-semibold opacity-70">{game[durasiKey]}</p>
        <p class="mt-4 font-display text-[2.75rem] leading-none font-bold">
          {currency}{game.harga}
        </p>
        <p class="mt-3 text-sm opacity-80">{game[sesuaiKey]}</p>
        <ul class="mt-5 flex-1 space-y-2.5 text-[15px]">
          {f(game, 'termasukKey').map((item) => (
            <li class="flex gap-2">
              <span class="mt-0.5 shrink-0 font-bold text-mint">✓</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
        <a
          href="#booking"
          data-pakej={game.id}
          class="pakej-cta pop mt-7 rounded-2xl bg-coral py-3.5 text-center font-display text-xl font-bold text-white shadow-lg shadow-coral/30 hover:bg-coral-dark"
        >
          {t.pakej.book}
        </a>
      </article>
    </div>

    <p class="mt-8 text-center text-sm opacity-80">{t.pakej.nota}</p>
  </div>
</section>

<script>
  // Pre-select the chosen package in the booking form
  document.querySelectorAll('.pakej-cta').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-pakej');
      const radio = document.querySelector(`input[name="pakej"][value="${id}"]`);
      if (radio instanceof HTMLInputElement) radio.checked = true;
    });
  });
</script>
