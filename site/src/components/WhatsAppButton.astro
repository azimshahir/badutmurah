---
import { getT, getWhatsAppLink } from '../i18n/index.js';

const { locale = 'en' } = Astro.props;
const t = getT(locale);
---

<a
  id="wa-float"
  href={getWhatsAppLink(locale)}
  target="_blank"
  rel="noopener"
  aria-label={t.whatsapp.aria}
  class="pop fixed right-4 bottom-4 z-50 flex h-14 w-14 items-center justify-center rounded-full bg-[#25D366] shadow-lg md:right-6 md:bottom-6"
>
  <svg viewBox="0 0 32 32" class="h-8 w-8 fill-white" aria-hidden="true">
    <path
      d="M16 3C9.383 3 4 8.383 4 15c0 2.61.844 5.027 2.27 7l-1.5 5.484 5.648-1.48A11.9 11.9 0 0 0 16 27c6.617 0 12-5.383 12-12S22.617 3 16 3zm0 2c5.535 0 10 4.465 10 10s-4.465 10-10 10a9.94 9.94 0 0 1-5.098-1.398l-.359-.211-3.355.879.891-3.262-.234-.375A9.92 9.92 0 0 1 6 15c0-5.535 4.465-10 10-10zm-4.5 5c-.273 0-.71.102-1.082.5-.371.398-1.418 1.383-1.418 3.375s1.453 3.918 1.652 4.188c.2.27 2.81 4.48 6.938 6.113 3.43 1.352 4.129 1.082 4.875 1.016.746-.067 2.406-.985 2.746-1.938.34-.953.34-1.77.238-1.937-.101-.168-.371-.27-.777-.473-.406-.203-2.406-1.187-2.781-1.324-.375-.137-.649-.203-.922.203-.273.406-1.055 1.324-1.293 1.598-.238.27-.476.305-.883.101-.406-.203-1.715-.632-3.266-2.015-1.207-1.075-2.023-2.403-2.261-2.809-.239-.406-.026-.625.177-.828.183-.182.407-.476.61-.714.203-.239.27-.407.406-.68.136-.27.068-.508-.034-.711-.101-.203-.906-2.207-1.273-3.016-.336-.742-.688-.633-.938-.645-.242-.011-.52-.014-.714-.014z"
    />
  </svg>
</a>
