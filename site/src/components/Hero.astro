---
import { WHATSAPP_LINK } from '../lib/site.js';
---

<header class="relative overflow-hidden">
  <!-- soft sunny blob behind the photo -->
  <div
    class="pointer-events-none absolute -top-24 -right-24 h-96 w-96 rounded-full bg-sunny/30 blur-3xl"
    aria-hidden="true"
  >
  </div>

  <div class="mx-auto max-w-[1100px] px-5 pt-10 pb-16 md:pt-16 md:pb-24">
    <div class="grid items-center gap-10 md:grid-cols-2">
      <div>
        <p class="mb-3 inline-block rounded-full bg-sunny/40 px-4 py-1 font-display text-sm font-semibold">
          Badut Jim · KL &amp; Selangor
        </p>
        <h1 class="text-4xl leading-tight font-bold md:text-5xl">
          Badut Profesional Untuk Birthday Party Anak Anda
        </h1>
        <p class="mt-4 text-lg opacity-90">
          9 tahun pengalaman menghiburkan kanak-kanak di seluruh KL &amp; Selangor.
          Harga jelas, book online dalam 2 minit — macam book hotel.
        </p>

        <div class="mt-7 flex flex-col gap-3 sm:flex-row">
          <a
            href="#pakej"
            class="lift rounded-2xl bg-coral px-7 py-4 text-center font-display text-xl font-bold text-white shadow-lg shadow-coral/30 hover:bg-coral-dark"
          >
            Semak Pakej &amp; Book
          </a>
          <a
            href={WHATSAPP_LINK}
            target="_blank"
            rel="noopener"
            class="lift rounded-2xl border-2 border-navy/15 bg-white px-7 py-4 text-center font-display text-xl font-bold hover:border-navy/40 hover:bg-navy/[0.03]"
          >
            Tanya Dulu di WhatsApp
          </a>
        </div>

        <ul class="mt-8 flex flex-wrap gap-x-6 gap-y-2 text-sm font-semibold">
          <li class="flex items-center gap-1.5"><span class="text-mint">✓</span> 9 Tahun Pengalaman</li>
          <li class="flex items-center gap-1.5"><span class="text-mint">✓</span> 500+ Majlis</li>
          <li class="flex items-center gap-1.5"><span class="text-mint">✓</span> Free Travel KL &amp; Selangor</li>
        </ul>
      </div>

      <div class="relative">
        <!-- balloon doodle accent (design-brief: satu-dua doodle kecil) -->
        <svg
          viewBox="0 0 40 64"
          class="absolute -top-8 -left-4 h-16 w-10 -rotate-12 md:-top-10 md:-left-8"
          aria-hidden="true"
        >
          <ellipse cx="20" cy="18" rx="14" ry="17" fill="#EF476F" opacity="0.85"></ellipse>
          <path d="M20 35 l-3 5 h6 z" fill="#EF476F" opacity="0.85"></path>
          <path d="M20 40 C 18 48, 24 52, 20 62" stroke="#1D3557" stroke-width="1.5" fill="none" opacity="0.5"></path>
        </svg>
        <img
          src="/images/hero.webp"
          alt="Badut Jim bersama keluarga di birthday party"
          width="720"
          height="474"
          fetchpriority="high"
          class="w-full rounded-3xl object-cover shadow-xl"
        />
        <div
          class="absolute -bottom-3 -left-3 -z-10 h-full w-full rounded-3xl bg-sunny"
          aria-hidden="true"
        >
        </div>
      </div>
    </div>
  </div>
</header>
