    <div class="grid gap-8 md:grid-cols-3">
      <div>
        <p class="font-display text-xl font-semibold">Badut Jim</p>
        <p class="mt-2 text-sm opacity-80">Menceriakan majlis kanak-kanak sejak 2011.</p>
      </div>
      <div>
        <p class="font-display font-semibold">Kawasan</p>
        <p class="mt-2 text-sm opacity-80">
          Kuala Lumpur · Selangor · Putrajaya · Nilai · Seremban
        </p>
      </div>
      <div>
        <p class="font-display font-semibold">Hubungi Kami</p>
        <ul class="mt-2 space-y-1 text-sm opacity-80">
          <li>
            <a href={WHATSAPP_LINK} target="_blank" rel="noopener" class="hover:underline">
              WhatsApp {WHATSAPP_NUMBER.replace(/^60/, '0')}
            </a>
          </li>
          <li><a href="mailto:badutjim@gmail.com" class="hover:underline">badutjim@gmail.com</a></li>
