---
// Footer: white, soft slate text, circle social icons (template v4)
import { WHATSAPP_NUMBER } from '../lib/site.js';
import Wordmark from './Wordmark.astro';
import { getT, getWhatsAppLink, localePath } from '../i18n/index.js';

const { locale = 'en' } = Astro.props;
const t = getT(locale);
const waLink = getWhatsAppLink(locale);
const p = (path) => localePath(locale, path);

const socials = [
  { label: 'Facebook', short: 'f', href: 'https://facebook.com/Badutjim' },
  { label: 'TikTok', short: 't', href: 'https://www.tiktok.com/@badut.jeem' },
  { label: 'Instagram', short: 'i', href: 'https://www.instagram.com/badutjim/' },
];
---

<footer class="mt-8 border-t border-navy/5 bg-white py-12">
  <div class="mx-auto max-w-[1100px] px-5">
    <div class="grid gap-10 text-center text-sm md:grid-cols-3 md:text-left">
      <div>
        <p class="flex items-center justify-center gap-2 md:justify-start">
          <img src="/images/logo-mascot.png" alt="" width="512" height="410" class="h-9 w-auto" aria-hidden="true" />
          <Wordmark class="h-7" />
        </p>
        <p class="mt-3 leading-relaxed opacity-70">{t.footer.tagline}</p>
        <p class="mt-2 opacity-70">{t.footer.coverage}</p>
      </div>
      <div>
        <p class="font-display text-base font-bold">{t.footer.links}</p>
        <ul class="mt-3 space-y-2 opacity-70">
          <li><a href={p('/') + '#pakej'} class="hover:text-coral-dark hover:opacity-100">{t.footer.linkPakej}</a></li>
          <li><a href={p('/our-clown')} class="hover:text-coral-dark hover:opacity-100">{t.nav.jimClown}</a></li>
          <li><a href={p('/edutainment')} class="hover:text-coral-dark hover:opacity-100">{t.nav.edutainment}</a></li>
          <li><a href={p('/') + '#faq'} class="hover:text-coral-dark hover:opacity-100">{t.footer.linkFaq}</a></li>
          <li><a href={p('/') + '#booking'} class="hover:text-coral-dark hover:opacity-100">{t.footer.linkBook}</a></li>
        </ul>
      </div>
      <div class="md:text-right">
        <p class="font-display text-base font-bold">{t.footer.hubungi}</p>
        <ul class="mt-3 space-y-2 opacity-70">
          <li>
            <a href={waLink} target="_blank" rel="noopener" class="hover:text-coral-dark hover:opacity-100">
              WhatsApp {WHATSAPP_NUMBER.replace(/^60/, '0')}
            </a>
          </li>
          <li><a href="mailto:badutjim@gmail.com" class="hover:text-coral-dark hover:opacity-100">badutjim@gmail.com</a></li>
        </ul>
        <ul class="mt-4 flex justify-center gap-3 md:justify-end">
          {
            socials.map((s) => (
              <li>
                <a
                  href={s.href}
                  target="_blank"
                  rel="noopener"
                  aria-label={s.label}
                  class="pop flex h-9 w-9 items-center justify-center rounded-full bg-navy/5 font-bold transition hover:bg-coral hover:text-white"
                >
                  {s.short}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
    <p class="mt-10 border-t border-navy/5 pt-6 text-center text-xs opacity-50">
      {t.footer.copyright}
    </p>
  </div>
</footer>
