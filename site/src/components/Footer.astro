---
// 3-column footer
import { WHATSAPP_NUMBER } from '../lib/site.js';
import { getT, getWhatsAppLink, localePath } from '../i18n/index.js';

const { locale = 'en' } = Astro.props;
const t = getT(locale);
const waLink = getWhatsAppLink(locale);
const p = (path) => localePath(locale, path);
---

<footer class="mt-8 bg-navy py-14 text-white">
  <div class="mx-auto max-w-[1100px] px-5">
    <div class="grid gap-10 text-center md:grid-cols-3 md:text-left">
      <div>
        <p class="flex items-center justify-center gap-2 font-display text-xl font-bold md:justify-start">
          <span aria-hidden="true">🤡</span> badutmurah.my
        </p>
        <p class="mt-3 text-sm leading-relaxed opacity-80">{t.footer.tagline}</p>
        <p class="mt-2 text-sm opacity-80">{t.footer.coverage}</p>
      </div>
      <div>
        <p class="font-display font-semibold">{t.footer.links}</p>
        <ul class="mt-3 space-y-2 text-sm opacity-80">
          <li><a href={p('/') + '#pakej'} class="hover:underline">{t.footer.linkPakej}</a></li>
          <li><a href={p('/our-clown')} class="hover:underline">{t.nav.ourClown}</a></li>
          <li><a href={p('/edutainment')} class="hover:underline">{locale === 'en' ? 'Edutainment Projects' : 'Projek Edutainment'}</a></li>
          <li><a href={p('/') + '#faq'} class="hover:underline">{t.footer.linkFaq}</a></li>
          <li><a href={p('/') + '#booking'} class="hover:underline">{t.footer.linkBook}</a></li>
        </ul>
      </div>
      <div>
        <p class="font-display font-semibold">{t.footer.hubungi}</p>
        <ul class="mt-3 space-y-2 text-sm opacity-80">
          <li>
            <a href={waLink} target="_blank" rel="noopener" class="hover:underline">
              WhatsApp {WHATSAPP_NUMBER.replace(/^60/, '0')}
            </a>
          </li>
          <li><a href="mailto:badutjim@gmail.com" class="hover:underline">badutjim@gmail.com</a></li>
        </ul>
        <ul class="mt-4 flex justify-center gap-4 text-sm md:justify-start">
          <li><a href="https://facebook.com/Badutjim" target="_blank" rel="noopener" class="opacity-80 hover:underline hover:opacity-100">Facebook</a></li>
          <li><a href="https://www.tiktok.com/@badut.jeem" target="_blank" rel="noopener" class="opacity-80 hover:underline hover:opacity-100">TikTok</a></li>
          <li><a href="https://www.instagram.com/badutjim/" target="_blank" rel="noopener" class="opacity-80 hover:underline hover:opacity-100">Instagram</a></li>
        </ul>
      </div>
    </div>
    <p class="mt-10 border-t border-white/15 pt-6 text-center text-sm opacity-60">
      {t.footer.copyright}
    </p>
  </div>
</footer>
