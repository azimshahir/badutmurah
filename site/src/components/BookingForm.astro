---
// Booking form. Fields & validation per docs/booking-spec.md.
// Option VALUES stay identical across locales (API payload contract); labels translate.
import pricing from '../../docs/pricing.json';
import { getT, getWhatsAppLink } from '../i18n/index.js';

const { locale = 'en' } = Astro.props;
const t = getT(locale);
const waLink = getWhatsAppLink(locale);
const { pakej, currency } = pricing;
const nameKey = t.pakej.nameKey;
const durasiKey = t.pakej.durasiKey;

const slotMasa = ['10am', '11am', '12pm', '2pm', '3pm', '4pm', '5pm'];
const masaLainValue = 'Lain-lain (nyatakan di nota)';
const bilKanak = ['<10', '10-20', '20-30', '30+'];
---

<section id="booking" class="scroll-mt-28 py-16 md:py-24">
  <div class="mx-auto max-w-[680px] px-5">
    <div class="relative mx-auto w-fit">
      <svg viewBox="0 0 48 32" class="absolute -top-6 -right-10 h-8 w-12" aria-hidden="true">
        <circle cx="8" cy="20" r="3" fill="#FFD166"></circle>
        <circle cx="24" cy="8" r="2.5" fill="#06D6A0"></circle>
        <rect x="36" y="16" width="6" height="6" rx="1.5" fill="#EF476F" transform="rotate(20 39 19)"></rect>
      </svg>
      <h2 class="squiggle text-center text-3xl font-bold md:text-4xl">{t.booking.heading}</h2>
    </div>
    <p class="mx-auto mt-4 max-w-lg text-center opacity-90">{t.booking.sub}</p>

    <form
      id="booking-form"
      class="mt-10 space-y-5 rounded-3xl bg-white p-6 shadow-lg md:p-10"
      novalidate
      data-msg-sending={t.booking.menghantar}
      data-msg-send={t.booking.hantar}
      data-msg-error={t.booking.errorTeknikal}
      data-msg-error-suffix={t.booking.errorSuffix}
      data-msg-error-wa={t.booking.errorWhatsapp}
      data-msg-error-phone={t.booking.errorPhone}
      data-wa-link={waLink}
    >
      <div>
        <label for="nama" class="mb-1.5 block font-semibold">{t.booking.nama}</label>
        <input type="text" id="nama" name="nama" required autocomplete="name"
          class="w-full rounded-2xl border-2 border-navy/15 bg-cream px-4 py-3 outline-none focus:border-coral" />
      </div>

      <div>
        <label for="phone" class="mb-1.5 block font-semibold">{t.booking.phone}</label>
        <input type="tel" id="phone" name="phone" required inputmode="tel" autocomplete="tel" placeholder="01X-XXXXXXX"
          class="w-full rounded-2xl border-2 border-navy/15 bg-cream px-4 py-3 outline-none focus:border-coral" />
      </div>

      <div class="grid gap-5 sm:grid-cols-2">
        <div>
          <label for="tarikh" class="mb-1.5 block font-semibold">{t.booking.tarikh}</label>
          <input type="date" id="tarikh" name="tarikh" required
            class="w-full rounded-2xl border-2 border-navy/15 bg-cream px-4 py-3 outline-none focus:border-coral" />
        </div>
        <div>
          <label for="masa" class="mb-1.5 block font-semibold">{t.booking.masa}</label>
          <select id="masa" name="masa" required
            class="w-full rounded-2xl border-2 border-navy/15 bg-cream px-4 py-3 outline-none focus:border-coral">
            <option value="" disabled selected>{t.booking.masaPlaceholder}</option>
            {slotMasa.map((s) => <option value={s}>{s}</option>)}
            <option value={masaLainValue}>{t.booking.masaLain}</option>
          </select>
        </div>
      </div>

      <fieldset>
        <legend class="mb-2 font-semibold">{t.booking.pilihPakej}</legend>
        <div class="grid gap-3 sm:grid-cols-3">
          {
            pakej.map((p) => (
              <label class="cursor-pointer rounded-2xl border-2 border-navy/15 bg-cream p-4 text-center transition-colors hover:border-coral/50 has-checked:border-coral has-checked:bg-coral/5 has-focus-visible:outline-3 has-focus-visible:outline-coral">
                <input type="radio" name="pakej" value={p.id} required class="sr-only" />
                <span class="block font-display font-semibold">{p[nameKey]}</span>
                <span class="block text-sm opacity-70">{p[durasiKey]}</span>
                <span class="block font-display text-xl font-bold">
                  {currency}
                  {p.harga}
                </span>
              </label>
            ))
          }
        </div>
      </fieldset>

      <div>
        <label for="lokasi" class="mb-1.5 block font-semibold">
          {t.booking.lokasi} <span class="font-normal opacity-75">{t.booking.lokasiHint}</span>
        </label>
        <input type="text" id="lokasi" name="lokasi" required
          class="w-full rounded-2xl border-2 border-navy/15 bg-cream px-4 py-3 outline-none focus:border-coral" />
      </div>

      <div>
        <label for="bil_kanak" class="mb-1.5 block font-semibold">
          {t.booking.bilKanak} <span class="font-normal opacity-75">{t.booking.bilKanakHint}</span>
        </label>
        <select id="bil_kanak" name="bil_kanak"
          class="w-full rounded-2xl border-2 border-navy/15 bg-cream px-4 py-3 outline-none focus:border-coral">
          <option value="">{t.booking.bilKanakPlaceholder}</option>
          {bilKanak.map((b) => <option value={b}>{b}</option>)}
        </select>
      </div>

      <div>
        <label for="nota" class="mb-1.5 block font-semibold">
          {t.booking.nota} <span class="font-normal opacity-75">{t.booking.notaHint}</span>
        </label>
        <textarea id="nota" name="nota" rows="3"
          class="w-full rounded-2xl border-2 border-navy/15 bg-cream px-4 py-3 outline-none focus:border-coral"></textarea>
      </div>

      <!-- Honeypot: hidden from humans, bots fill it in -->
      <div class="absolute -left-[9999px]" aria-hidden="true">
        <label for="website">Website</label>
        <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
      </div>

      <p id="form-error" hidden class="rounded-2xl bg-coral/10 p-4 text-[15px] font-semibold text-coral-dark"></p>

      <button
        type="submit"
        id="submit-btn"
        class="pop w-full rounded-2xl bg-coral px-7 py-4 font-display text-xl font-bold text-white shadow-lg shadow-coral/30 hover:bg-coral-dark disabled:opacity-60"
      >
        {t.booking.hantar}
      </button>
    </form>

    <div id="booking-success" hidden class="mt-10 rounded-3xl bg-mint/15 p-8 text-center">
      <p class="text-xl font-semibold">{t.booking.success}</p>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('booking-form') as HTMLFormElement;
  const errorBox = document.getElementById('form-error') as HTMLParagraphElement;
  const successBox = document.getElementById('booking-success') as HTMLDivElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const msg = form.dataset;

  // Min date: today + 2 days (booking-spec.md)
  const tarikh = document.getElementById('tarikh') as HTMLInputElement;
  const min = new Date();
  min.setDate(min.getDate() + 2);
  tarikh.min = min.toISOString().slice(0, 10);

  function showError(text: string) {
    errorBox.innerHTML = `${text} ${msg.msgErrorSuffix} <a href="${msg.waLink}" target="_blank" rel="noopener" class="underline">${msg.msgErrorWa}</a>.`;
    errorBox.hidden = false;
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorBox.hidden = true;

    if (!form.reportValidity()) return;

    const data = Object.fromEntries(new FormData(form).entries()) as Record<string, string>;

    // Malaysian mobile: 01X-XXXXXXX, strip spaces/dashes before validating
    const phone = data.phone.replace(/[\s-]/g, '');
    if (!/^01[0-9]{8,9}$/.test(phone)) {
      showError(msg.msgErrorPhone!);
      return;
    }
    data.phone = phone;

    submitBtn.disabled = true;
    submitBtn.textContent = msg.msgSending!;

    try {
      const res = await fetch('/api/booking', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      const json = await res.json();
      if (!json.ok) throw new Error(json.error || 'unknown');
      form.hidden = true;
      successBox.hidden = false;
      successBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
    } catch {
      showError(msg.msgError!);
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = msg.msgSend!;
    }
  });
</script>
