---
const gambar = [
  { src: '/images/gallery-1.webp', alt: 'Badut Jim buat balloon twisting untuk kanak-kanak di event' },
  { src: '/images/gallery-2.webp', alt: 'Badut Jim menghiburkan keluarga dengan belon' },
  { src: '/images/gallery-3.webp', alt: 'Kanak-kanak gembira dengan belon bersama Badut Jim' },
  { src: '/images/gallery-4.webp', alt: 'Badut Jim dalam kostum penuh di majlis' },
  { src: '/images/gallery-5.webp', alt: 'Badut Jim di majlis korporat dengan belon dan confetti' },
  { src: '/images/gallery-6.webp', alt: 'Bouncing castle di birthday party' },
  { src: '/images/gallery-7.webp', alt: 'Kanak-kanak menonton puppet show' },
];
---

<section class="bg-white py-16 md:py-24">
  <div class="mx-auto max-w-[1100px] px-5">
    <h2 class="squiggle mx-auto w-fit text-center text-3xl font-bold md:text-4xl">
      Detik-Detik Ceria
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-center opacity-90">
      Sebahagian daripada majlis yang pernah kami serikan.
    </p>

    <div class="mt-14 grid grid-cols-2 gap-3 md:grid-cols-4 md:gap-4">
      {
        gambar.map((g, i) => (
          <img
            src={g.src}
            alt={g.alt}
            loading="lazy"
            decoding="async"
            width="400"
            height="300"
            class:list={[
              'aspect-[4/3] w-full rounded-2xl object-cover transition-transform duration-300 hover:scale-[1.02] motion-reduce:transition-none motion-reduce:hover:scale-100',
              i === 0 && 'col-span-2 row-span-2 aspect-square md:aspect-[4/3] h-full',
            ]}
          />
        ))
      }
    </div>
  </div>
</section>
