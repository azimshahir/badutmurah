---
// Sticky navbar: logo + Book pill, Our Clown dropdown, Edutainment Project
// with arrow + callout tag, language toggle. Hover states: .nav-link underline, .pop lift.
// Mobile (< lg): hamburger opens a full-width dropdown panel — the old flex-wrap
// link row overflowed off-screen on narrow phones, so this replaces it entirely.
import Wordmark from './Wordmark.astro';
import { getT, localePath, altLocalePath } from '../i18n/index.js';

const { locale = 'en', pathname = '/' } = Astro.props;
const t = getT(locale);
const p = (path) => localePath(locale, path);
const altHref = altLocalePath(locale, pathname);
const isHome = pathname === '/' || pathname === '/ms/';
const isClown = pathname.endsWith('/our-clown');
const isEdu = pathname.endsWith('/edutainment');
---

<nav class="sticky top-0 z-40 bg-white/80 shadow-sm backdrop-blur-md">
  <div class="mx-auto flex max-w-[1240px] items-center justify-between gap-2 px-4 py-3 md:px-5">
    <a href={p('/')} class="flex min-w-0 items-center gap-1.5 md:gap-2">
      <img src="/images/logo-mascot.png" alt="" width="512" height="410" class="logo-emoji h-7 w-auto shrink-0 sm:h-8 md:h-11" aria-hidden="true" />
      <Wordmark class="h-5 w-auto shrink-0 sm:h-6 md:h-9" />
    </a>

    <div class="hidden items-center gap-5 text-[15px] font-semibold whitespace-nowrap lg:flex">
      <a href={p('/')} class="nav-link hover:text-coral-dark" aria-current={isHome ? 'page' : undefined}>{t.nav.home}</a>

      <!-- Our Clown dropdown (ready for more clowns later) -->
      <div class="group relative">
        <button
          type="button"
          class="nav-link flex items-center gap-1 hover:text-coral-dark"
          aria-haspopup="true"
          aria-current={isClown ? 'page' : undefined}
        >
          {t.nav.ourClown}
          <span class="text-xs transition-transform duration-200 group-focus-within:rotate-180 group-hover:rotate-180" aria-hidden="true">▾</span>
        </button>
        <div
          class="invisible absolute top-full left-0 translate-y-1 pt-2 opacity-0 transition-all duration-200 group-focus-within:visible group-focus-within:translate-y-0 group-focus-within:opacity-100 group-hover:visible group-hover:translate-y-0 group-hover:opacity-100"
        >
          <div class="min-w-44 rounded-2xl border border-navy/10 bg-white p-2 shadow-xl shadow-navy/10">
            <a href={p('/our-clown')} class="block rounded-xl px-4 py-2.5 transition-colors hover:bg-sunny/30 hover:text-coral-dark">
              🤡 {t.nav.jimClown}
            </a>
          </div>
        </div>
      </div>

      <a href={p('/package')} class="nav-link hover:text-coral-dark">{t.nav.pakej}</a>

      <!-- Edutainment Project with arrow + callout tag -->
      <span class="flex items-center gap-1.5">
        <a href={p('/edutainment')} class="nav-link hover:text-coral-dark" aria-current={isEdu ? 'page' : undefined}>{t.nav.edutainment}</a>
        <svg viewBox="0 0 34 16" class="h-4 w-8 shrink-0 text-coral" aria-hidden="true">
          <path d="M32 8 H6" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round"></path>
          <path d="M12 2 L4 8 L12 14" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
        <a
          href={p('/edutainment')}
          tabindex="-1"
          class="wiggle pop rounded-full bg-gradient-to-r from-sunny to-coral/70 px-3.5 py-1.5 font-display text-sm font-bold whitespace-nowrap text-navy shadow-md"
        >
          ✨ {t.nav.edutainmentTag}
        </a>
      </span>
    </div>

    <div class="flex shrink-0 items-center gap-2">
      <a
        href={p('/booking')}
        class="pop gradient-pink hidden rounded-full px-4 py-1.5 font-display text-sm font-bold whitespace-nowrap text-white shadow-lg shadow-coral/30 lg:block lg:px-6 lg:py-2 lg:text-base"
      >
        {t.nav.book}
      </a>

      <a
        href={altHref}
        class="pop hidden shrink-0 rounded-full border-2 border-navy/15 px-3 py-1.5 font-display text-sm font-bold hover:border-coral hover:bg-coral/5 hover:text-coral-dark lg:block"
        aria-label={locale === 'en' ? 'Tukar ke Bahasa Malaysia' : 'Switch to English'}
      >
        🌐 {t.nav.langLabel}
      </a>

      <!-- Mobile hamburger: opens the panel below, no JS framework needed -->
      <button
        id="nav-toggle"
        type="button"
        class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full border-2 border-navy/15 lg:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label={locale === 'en' ? 'Open menu' : 'Buka menu'}
      >
        <svg id="nav-toggle-icon" viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
          <path d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile dropdown panel: stacked full-width links, no overflow risk -->
  <div id="mobile-menu" class="hidden border-t border-navy/5 px-4 py-3 lg:hidden">
    <div class="flex flex-col gap-1 text-base font-semibold">
      <a
        href={p('/booking')}
        class="pop gradient-pink mb-1 rounded-full px-4 py-3 text-center font-display font-bold text-white shadow-lg shadow-coral/30"
      >
        ⭐ {t.nav.book}
      </a>
      <a href={p('/')} class="rounded-xl px-3 py-2.5 hover:bg-cream hover:text-coral-dark" aria-current={isHome ? 'page' : undefined}>{t.nav.home}</a>
      <a href={p('/our-clown')} class="rounded-xl px-3 py-2.5 hover:bg-cream hover:text-coral-dark" aria-current={isClown ? 'page' : undefined}>
        🤡 {t.nav.jimClown}
      </a>
      <a href={p('/package')} class="rounded-xl px-3 py-2.5 hover:bg-cream hover:text-coral-dark">{t.nav.pakej}</a>
      <a
        href={p('/edutainment')}
        class="wiggle mt-1 rounded-full bg-gradient-to-r from-sunny to-coral/70 px-4 py-2.5 text-center font-display font-bold text-navy"
        aria-current={isEdu ? 'page' : undefined}
      >
        ✨ {t.nav.edutainmentTag}
      </a>
      <a
        href={altHref}
        class="mt-2 rounded-xl border-2 border-navy/15 px-3 py-2.5 text-center hover:border-coral hover:text-coral-dark"
      >
        🌐 {locale === 'en' ? 'Bahasa Malaysia' : 'English'}
      </a>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('nav-toggle') as HTMLButtonElement;
  const menu = document.getElementById('mobile-menu') as HTMLDivElement;
  const icon = document.getElementById('nav-toggle-icon') as SVGElement;
  const openPath = 'M4 6h16M4 12h16M4 18h16';
  const closePath = 'M6 6l12 12M18 6L6 18';

  function setOpen(open: boolean) {
    menu.classList.toggle('hidden', !open);
    toggle.setAttribute('aria-expanded', String(open));
    icon.innerHTML = `<path d="${open ? closePath : openPath}"></path>`;
  }

  toggle.addEventListener('click', () => setOpen(menu.classList.contains('hidden')));
  menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
</script>
