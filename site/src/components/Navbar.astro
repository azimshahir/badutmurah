---
// Sticky navbar: logo + Book pill, Our Clown dropdown, Edutainment Project
// with arrow + callout tag, language toggle. Hover states: .nav-link underline, .pop lift.
import Wordmark from './Wordmark.astro';
import { getT, localePath, altLocalePath } from '../i18n/index.js';

const { locale = 'en', pathname = '/' } = Astro.props;
const t = getT(locale);
const p = (path) => localePath(locale, path);
const altHref = altLocalePath(locale, pathname);
const isHome = pathname === '/' || pathname === '/ms/';
const isClown = pathname.endsWith('/our-clown');
const isEdu = pathname.endsWith('/edutainment');
---

<nav class="sticky top-0 z-40 bg-white/80 shadow-sm backdrop-blur-md">
  <div class="mx-auto flex max-w-[1240px] items-center justify-between gap-3 px-4 py-3 md:px-5">
    <div class="flex items-center gap-3">
      <a href={p('/')} class="flex items-center gap-2">
        <img src="/images/logo-mascot.png" alt="" width="512" height="410" class="logo-emoji h-10 w-auto md:h-11" aria-hidden="true" />
        <Wordmark class="h-7 md:h-9" />
      </a>
      <a
        href={p('/booking')}
        class="pop gradient-pink rounded-full px-4 py-1.5 font-display text-sm font-bold whitespace-nowrap text-white shadow-lg shadow-coral/30 md:px-6 md:py-2 md:text-base"
      >
        {t.nav.book}
      </a>
    </div>

    <div class="hidden items-center gap-5 text-[15px] font-semibold whitespace-nowrap lg:flex">
      <a href={p('/')} class="nav-link hover:text-coral-dark" aria-current={isHome ? 'page' : undefined}>{t.nav.home}</a>

      <!-- Our Clown dropdown (ready for more clowns later) -->
      <div class="group relative">
        <button
          type="button"
          class="nav-link flex items-center gap-1 hover:text-coral-dark"
          aria-haspopup="true"
          aria-current={isClown ? 'page' : undefined}
        >
          {t.nav.ourClown}
          <span class="text-xs transition-transform duration-200 group-focus-within:rotate-180 group-hover:rotate-180" aria-hidden="true">▾</span>
        </button>
        <div
          class="invisible absolute top-full left-0 translate-y-1 pt-2 opacity-0 transition-all duration-200 group-focus-within:visible group-focus-within:translate-y-0 group-focus-within:opacity-100 group-hover:visible group-hover:translate-y-0 group-hover:opacity-100"
        >
          <div class="min-w-44 rounded-2xl border border-navy/10 bg-white p-2 shadow-xl shadow-navy/10">
            <a href={p('/our-clown')} class="block rounded-xl px-4 py-2.5 transition-colors hover:bg-sunny/30 hover:text-coral-dark">
              🤡 {t.nav.jimClown}
            </a>
          </div>
        </div>
      </div>

      <a href={p('/package')} class="nav-link hover:text-coral-dark">{t.nav.pakej}</a>

      <!-- Edutainment Project with arrow + callout tag -->
      <span class="flex items-center gap-1.5">
        <a href={p('/edutainment')} class="nav-link hover:text-coral-dark" aria-current={isEdu ? 'page' : undefined}>{t.nav.edutainment}</a>
        <svg viewBox="0 0 34 16" class="h-4 w-8 shrink-0 text-coral" aria-hidden="true">
          <path d="M32 8 H6" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round"></path>
          <path d="M12 2 L4 8 L12 14" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
        <a
          href={p('/edutainment')}
          tabindex="-1"
          class="wiggle pop rounded-full bg-gradient-to-r from-sunny to-coral/70 px-3.5 py-1.5 font-display text-sm font-bold whitespace-nowrap text-navy shadow-md"
        >
          ✨ {t.nav.edutainmentTag}
        </a>
      </span>
    </div>

    <a
      href={altHref}
      class="pop shrink-0 rounded-full border-2 border-navy/15 px-3 py-1.5 font-display text-sm font-bold hover:border-coral hover:bg-coral/5 hover:text-coral-dark"
      aria-label={locale === 'en' ? 'Tukar ke Bahasa Malaysia' : 'Switch to English'}
    >
      🌐 {t.nav.langLabel}
    </a>
  </div>

  <!-- mobile page links row -->
  <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-1 border-t border-navy/5 px-4 py-2 text-sm font-semibold lg:hidden">
    <a href={p('/')} class="nav-link hover:text-coral-dark">{t.nav.home}</a>
    <a href={p('/our-clown')} class="nav-link hover:text-coral-dark">{t.nav.jimClown}</a>
    <a href={p('/package')} class="nav-link hover:text-coral-dark">{t.nav.pakej}</a>
    <a
      href={p('/edutainment')}
      class="wiggle pop rounded-full bg-gradient-to-r from-sunny to-coral/70 px-3 py-1 font-display font-bold text-navy"
    >
      ✨ {t.nav.edutainment}
    </a>
  </div>
</nav>
