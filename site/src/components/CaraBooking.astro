---
const langkah = [
  { tajuk: 'Isi Form', isi: 'Pilih tarikh, pakej, dan lokasi anda.' },
  { tajuk: 'Terima Confirmation', isi: 'Kami confirm availability dalam 1 jam melalui WhatsApp.' },
  { tajuk: 'Bayar Deposit', isi: 'RM100 untuk kunci tarikh. Selesai — jumpa di majlis!' },
];
---

<section class="py-16 md:py-24">
  <div class="mx-auto max-w-[1100px] px-5">
    <h2 class="squiggle mx-auto w-fit text-center text-3xl font-bold md:text-4xl">
      Cara Booking
    </h2>

    <ol class="mt-14 grid gap-6 md:grid-cols-3">
      {
        langkah.map((l, i) => (
          <li class="tilt rounded-3xl bg-white p-8 shadow-sm">
            <span class="flex h-12 w-12 items-center justify-center rounded-full bg-coral font-display text-xl font-bold text-white shadow-md shadow-coral/30">
              {i + 1}
            </span>
            <h3 class="mt-4 text-xl font-semibold">{l.tajuk}</h3>
            <p class="mt-2 text-[15px] opacity-90">{l.isi}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
