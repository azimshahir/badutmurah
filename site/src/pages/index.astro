---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Divider from '../components/Divider.astro';
import Pakej from '../components/Pakej.astro';
import Kenapa from '../components/Kenapa.astro';
import Gallery from '../components/Gallery.astro';
import CaraBooking from '../components/CaraBooking.astro';
import Testimoni from '../components/Testimoni.astro';
import FAQ from '../components/FAQ.astro';
import BookingForm from '../components/BookingForm.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

const CREAM = '#FFFBF5';
const WHITE = '#FFFFFF';
const NAVY = '#1D3557';
---

<Layout>
  <Hero />
  <main>
    <Divider from={CREAM} to={WHITE} />
    <Pakej />
    <Divider from={WHITE} to={CREAM} />
    <Kenapa />
    <Divider from={CREAM} to={WHITE} />
    <Gallery />
    <Divider from={WHITE} to={CREAM} />
    <CaraBooking />
    <Divider from={CREAM} to={WHITE} />
    <Testimoni />
    <Divider from={WHITE} to={CREAM} />
    <FAQ />
    <Divider from={CREAM} to={WHITE} />
    <BookingForm />
    <Divider from={WHITE} to={NAVY} />
  </main>
  <Footer />
  <WhatsAppButton />
</Layout>
